<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prompt Enhancer · expert tool</title>
    <style>
        /* ─────────── reset & base ─────────── */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            /* light mode – clean, minimal, neutral */
            --bg: #f0f2f5;
            --bg-card: #ffffff;
            --bg-input: #f4f6f9;
            --bg-output: #f4f6f9;
            --text-primary: #1a1a2e;
            --text-secondary: #2d3a4a;
            --text-muted: #6b7a8a;
            --border-light: #dce0e6;
            --border-focus: #2d5f9e;
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04);
            --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.06);
            --accent: #2d5f9e;
            --accent-hover: #1d4a7a;
            --success: #2b8a5e;
            --radius: 12px;
            --transition: 0.25s ease;
        }

        /* ─── DARK MODE: Deep, authoritative ─── */
        body.dark {
            --bg: #0a0e14;
            --bg-card: #121820;
            --bg-input: #0f151d;
            --bg-output: #0f151d;
            --text-primary: #e8edf4;
            --text-secondary: #bcc8d8;
            --text-muted: #7a8aa0;
            --border-light: #1e2a3a;
            --border-focus: #5a9ae0;
            --shadow-sm: 0 1px 4px rgba(0, 0, 0, 0.6);
            --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.7);
            --accent: #5a9ae0;
            --accent-hover: #7bb3ff;
            --success: #4caf84;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.6;
            padding: 2rem 1.2rem;
            min-height: 100vh;
            display: flex;
            align-items: center;
            transition: background var(--transition), color var(--transition);
        }

        .container {
            max-width: 1120px;
            margin: 0 auto;
            width: 100%;
        }

        /* ─────────── header ─────────── */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.2rem 0 0.8rem;
            border-bottom: 2px solid var(--border-light);
            margin-bottom: 1.8rem;
            transition: border-color var(--transition);
        }

        .header-title {
            font-size: 1.5rem;
            font-weight: 600;
            letter-spacing: -0.02em;
            color: var(--text-primary);
        }

        .header-title span {
            color: var(--text-muted);
            font-weight: 400;
        }

        .theme-toggle {
            background: none;
            border: none;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text-muted);
            cursor: pointer;
            padding: 0.3rem 0.8rem;
            border: 1px solid var(--border-light);
            border-radius: 40px;
            transition: var(--transition);
            font-family: inherit;
            letter-spacing: 0.03em;
        }

        .theme-toggle:hover {
            color: var(--text-primary);
            border-color: var(--text-muted);
        }

        /* ─────────── options bar ─────────── */
        .options-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 0.8rem 1.5rem;
            align-items: center;
            padding: 0.6rem 0 1.2rem;
            margin-bottom: 0.2rem;
            border-bottom: 1px solid var(--border-light);
            transition: border-color var(--transition);
        }

        .option-group {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.3rem 0.6rem;
        }

        .option-label {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
            margin-right: 0.2rem;
        }

        .option-btn {
            background: var(--bg-input);
            border: 1px solid var(--border-light);
            border-radius: 40px;
            padding: 0.25rem 1.2rem;
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text-secondary);
            cursor: pointer;
            transition: var(--transition);
            font-family: inherit;
            white-space: nowrap;
        }

        .option-btn:hover {
            border-color: var(--text-muted);
            color: var(--text-primary);
        }

        .option-btn.active {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
            box-shadow: 0 2px 8px rgba(90, 154, 224, 0.2);
        }

        body.dark .option-btn.active {
            color: #0a0e14;
        }

        .option-btn.active:hover {
            background: var(--accent-hover);
            border-color: var(--accent-hover);
        }

        /* toggles */
        .toggle-group {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .toggle-switch {
            position: relative;
            width: 36px;
            height: 20px;
            background: var(--border-light);
            border-radius: 20px;
            cursor: pointer;
            transition: background var(--transition);
            flex-shrink: 0;
        }

        .toggle-switch.active {
            background: var(--accent);
        }

        .toggle-switch .knob {
            position: absolute;
            top: 2px;
            left: 2px;
            width: 16px;
            height: 16px;
            background: #fff;
            border-radius: 50%;
            transition: transform var(--transition);
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
        }

        .toggle-switch.active .knob {
            transform: translateX(16px);
        }

        .toggle-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 400;
        }

        /* ─────────── grid ─────────── */
        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 1.2rem;
        }

        @media (max-width: 780px) {
            .grid {
                grid-template-columns: 1fr;
                gap: 1rem;
            }
            .options-bar {
                flex-direction: column;
                align-items: stretch;
                gap: 0.6rem;
            }
            .option-group {
                flex-wrap: wrap;
            }
        }

        .panel {
            background: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: var(--radius);
            padding: 1.4rem;
            box-shadow: var(--shadow-sm);
            transition: background var(--transition), border-color var(--transition), box-shadow var(--transition);
        }

        .panel:focus-within {
            border-color: var(--border-focus);
            box-shadow: var(--shadow-md);
        }

        .panel-label {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            margin-bottom: 0.7rem;
        }

        .panel-label .count {
            font-weight: 400;
            text-transform: none;
            letter-spacing: 0;
        }

        textarea {
            width: 100%;
            min-height: 240px;
            background: var(--bg-input);
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 0.8rem 1rem;
            font-family: inherit;
            font-size: 0.95rem;
            line-height: 1.7;
            color: var(--text-primary);
            resize: vertical;
            transition: background var(--transition), border-color var(--transition), color var(--transition);
            outline: none;
        }

        textarea:focus {
            border-color: var(--border-focus);
            box-shadow: 0 0 0 3px rgba(90, 154, 224, 0.08);
        }

        textarea::placeholder {
            color: var(--text-muted);
            opacity: 0.4;
        }

        .output-area {
            background: var(--bg-output);
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 0.8rem 1rem;
            min-height: 240px;
            font-size: 0.95rem;
            line-height: 1.7;
            color: var(--text-secondary);
            white-space: pre-wrap;
            word-wrap: break-word;
            transition: background var(--transition), border-color var(--transition), color var(--transition);
            overflow-y: auto;
            max-height: 520px;
        }

        .output-area .placeholder {
            color: var(--text-muted);
            opacity: 0.35;
            font-style: italic;
        }

        /* ─────────── actions ─────────── */
        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.8rem;
            align-items: center;
            margin-top: 0.2rem;
            padding-top: 0.8rem;
            border-top: 1px solid var(--border-light);
            transition: border-color var(--transition);
        }

        .btn {
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 0.5rem 1.8rem;
            border-radius: 40px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: background var(--transition), transform 0.15s, box-shadow var(--transition);
            font-family: inherit;
            letter-spacing: 0.02em;
        }

        .btn:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(90, 154, 224, 0.25);
        }

        .btn:active {
            transform: scale(0.97);
        }

        .btn-secondary {
            background: var(--bg-input);
            color: var(--text-secondary);
            border: 1px solid var(--border-light);
        }

        .btn-secondary:hover {
            background: var(--border-light);
            color: var(--text-primary);
            box-shadow: none;
        }

        .btn-copy {
            background: none;
            border: 1px solid var(--border-light);
            color: var(--text-muted);
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            font-family: inherit;
        }

        .btn-copy:hover {
            border-color: var(--text-muted);
            color: var(--text-primary);
        }

        .btn-copy.copied {
            border-color: var(--success);
            color: var(--success);
        }

        .hint {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-left: auto;
            font-weight: 400;
        }

        /* ─────────── footer ─────────── */
        .footer {
            margin-top: 2.8rem;
            padding-top: 1.4rem;
            border-top: 1px solid var(--border-light);
            font-size: 0.8rem;
            color: var(--text-muted);
            text-align: center;
            transition: border-color var(--transition);
            letter-spacing: 0.02em;
        }

        /* ─────────── scrollbar polish ─────────── */
        .output-area::-webkit-scrollbar {
            width: 5px;
        }
        .output-area::-webkit-scrollbar-track {
            background: var(--bg-input);
            border-radius: 8px;
        }
        .output-area::-webkit-scrollbar-thumb {
            background: var(--border-light);
            border-radius: 8px;
        }
        .output-area::-webkit-scrollbar-thumb:hover {
            background: var(--text-muted);
        }

        @media (max-width: 550px) {
            .header {
                flex-wrap: wrap;
                gap: 0.4rem;
            }
            .header-title {
                font-size: 1.2rem;
            }
            .panel {
                padding: 1rem;
            }
            textarea,
            .output-area {
                min-height: 160px;
            }
            .actions {
                flex-direction: column;
                align-items: stretch;
            }
            .btn {
                text-align: center;
            }
            .hint {
                margin-left: 0;
                text-align: center;
            }
            .options-bar {
                gap: 0.4rem;
            }
            .option-group {
                gap: 0.3rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">

        <!-- ─── header ─── -->
        <header class="header">
            <div class="header-title">✦ prompt <span>enhancer</span></div>
            <button class="theme-toggle" id="themeToggle">Dark</button>
        </header>

        <!-- ─── options ─── -->
        <div class="options-bar">
            <div class="option-group">
                <span class="option-label">mode</span>
                <button class="option-btn active" data-mode="direct">Direct</button>
                <button class="option-btn" data-mode="research">Research</button>
                <button class="option-btn" data-mode="creative">Creative</button>
                <button class="option-btn" data-mode="technical">Technical</button>
            </div>
            <div class="option-group">
                <span class="option-label">options</span>
                <div class="toggle-group">
                    <div class="toggle-switch active" id="toggleExamples"><div class="knob"></div></div>
                    <span class="toggle-label">examples</span>
                </div>
                <div class="toggle-group">
                    <div class="toggle-switch active" id="toggleConstraints"><div class="knob"></div></div>
                    <span class="toggle-label">constraints</span>
                </div>
                <div class="toggle-group">
                    <div class="toggle-switch" id="toggleBrief"><div class="knob"></div></div>
                    <span class="toggle-label">brief</span>
                </div>
            </div>
        </div>

        <!-- ─── grid ─── -->
        <div class="grid">
            <div class="panel">
                <div class="panel-label">
                    <span>input</span>
                    <span class="count" id="charCount">0 chars</span>
                </div>
                <textarea id="inputPrompt" placeholder="Paste your prompt here…"></textarea>
            </div>
            <div class="panel">
                <div class="panel-label">
                    <span>enhanced</span>
                    <span class="count" id="outputCharCount">0 chars</span>
                </div>
                <div class="output-area" id="outputArea">
                    <span class="placeholder">enhanced prompt will appear here</span>
                </div>
            </div>
        </div>

        <!-- ─── actions ─── -->
        <div class="actions">
            <button class="btn" id="enhanceBtn">✦ enhance</button>
            <button class="btn btn-secondary" id="clearBtn">clear</button>
            <button class="btn-copy" id="copyBtn">copy</button>
            <span class="hint" id="statusHint">ready · ⌘+Enter</span>
        </div>

        <!-- ─── footer ─── -->
        <div class="footer">
            <span>✦ built with minimal CSS</span>
        </div>

    </div>

    <script>
        (function() {
            'use strict';

            // ─── DOM refs ───
            const inputEl = document.getElementById('inputPrompt');
            const outputEl = document.getElementById('outputArea');
            const charCount = document.getElementById('charCount');
            const outputCharCount = document.getElementById('outputCharCount');
            const enhanceBtn = document.getElementById('enhanceBtn');
            const clearBtn = document.getElementById('clearBtn');
            const copyBtn = document.getElementById('copyBtn');
            const statusHint = document.getElementById('statusHint');
            const toggleBtn = document.getElementById('themeToggle');
            const body = document.body;

            // ─── state ───
            let currentMode = 'direct';
            const options = {
                includeExamples: true,
                includeConstraints: true,
                includeBrief: false,
            };

            // ─── theme ───
            const saved = localStorage.getItem('theme');
            if (saved === 'dark') {
                body.classList.add('dark');
                toggleBtn.textContent = 'Light';
            } else {
                toggleBtn.textContent = 'Dark';
            }

            toggleBtn.addEventListener('click', function() {
                const isDark = body.classList.toggle('dark');
                toggleBtn.textContent = isDark ? 'Light' : 'Dark';
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });

            // ─── mode buttons ───
            document.querySelectorAll('[data-mode]').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-mode]').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    currentMode = this.dataset.mode;
                    statusHint.textContent = `mode: ${currentMode}`;
                    statusHint.style.color = 'var(--text-muted)';
                });
            });

            // ─── toggles ───
            document.querySelectorAll('.toggle-switch').forEach(t => {
                t.addEventListener('click', function() {
                    this.classList.toggle('active');
                    const key = this.id.replace('toggle', '').toLowerCase();
                    const map = {
                        examples: 'includeExamples',
                        constraints: 'includeConstraints',
                        brief: 'includeBrief'
                    };
                    options[map[key]] = this.classList.contains('active');
                    statusHint.textContent = `${key}: ${options[map[key]]}`;
                    statusHint.style.color = 'var(--text-muted)';
                });
            });

            // ─── char counts ───
            function updateCounts() {
                charCount.textContent = inputEl.value.length + ' chars';
                const outText = outputEl.textContent;
                const outCount = outText.replace(/\s/g, '').length;
                outputCharCount.textContent = outCount + ' chars';
            }
            inputEl.addEventListener('input', updateCounts);

            // ─── core enhancement ───
            function enhancePrompt(raw) {
                if (!raw || raw.trim() === '') return '⚠️ Please enter a prompt to enhance.';

                const mode = currentMode;
                const ex = options.includeExamples;
                const cs = options.includeConstraints;
                const br = options.includeBrief;

                let out = '';

                switch (mode) {
                    case 'direct':
                        out +=
                            'You are an expert prompt engineer. Refine the following prompt to be clear, specific, and actionable.\n\n';
                        break;
                    case 'research':
                        out +=
                            'You are a senior research assistant. Enhance this prompt to elicit thorough, evidence-based, and well-structured responses.\n\n';
                        break;
                    case 'creative':
                        out +=
                            'You are a creative director. Transform this prompt to inspire imaginative, original, and emotionally resonant outputs.\n\n';
                        break;
                    case 'technical':
                        out +=
                            'You are a principal software architect. Refine this prompt to demand precision, technical accuracy, and practical implementation details.\n\n';
                        break;
                    default:
                        out += 'You are an expert prompt engineer. Enhance the following prompt for clarity and effectiveness.\n\n';
                }

                if (br) {
                    out += '### BRIEF\n- Provide a 1-2 sentence summary of the core objective.\n- Clarify the primary goal and desired outcome.\n\n';
                }

                out += '### INSTRUCTIONS\n- Make the prompt crystal clear about the desired outcome.\n- Add specific details about tone, structure, and content.\n- Define the target audience (e.g., "developers," "recruiters").\n- Set the appropriate persona for the AI (e.g., "you are a senior developer").\n';

                if (cs) {
                    out +=
                        '- Set word or character limits where appropriate.\n- Define what to avoid (e.g., "no jargon," "no markdown").\n- Specify what to prioritize (e.g., "actionable items," "scannable").\n';
                }

                if (ex) {
                    out += '- Include a concrete example or reference to illustrate the desired output.\n';
                }

                out += '- Include a note to ask clarifying questions if the prompt is ambiguous.\n\n';

                out += '### FORMAT\n- Specify exact formatting: markdown, sections, bullet points, code blocks, tables, etc.\n- Describe the visual style: "clean," "minimal," "link-heavy," "single-line," etc.\n\n';

                out += '### FINAL OUTPUT\n- Provide the enhanced prompt in a clean, ready-to-use format.\n- Include a brief explanation of the enhancements made.\n\n';

                out += '--- START OF PROMPT ---\n';
                out += raw.trim();
                out += '\n--- END OF PROMPT ---';

                return out;
            }

            // ─── render ───
            function render(text) {
                outputEl.innerHTML = '';
                const lines = text.split('\n');
                for (let i = 0; i < lines.length; i++) {
                    const line = lines[i];
                    if (line.trim() === '') {
                        outputEl.appendChild(document.createElement('br'));
                    } else {
                        const span = document.createElement('span');
                        span.textContent = line;
                        outputEl.appendChild(span);
                        if (i < lines.length - 1) outputEl.appendChild(document.createElement('br'));
                    }
                }
                updateCounts();
            }

            // ─── actions ───
            function handleEnhance() {
                const raw = inputEl.value;
                if (!raw || raw.trim() === '') {
                    statusHint.textContent = '⚠️ please enter a prompt';
                    statusHint.style.color = 'var(--text-muted)';
                    return;
                }
                const enhanced = enhancePrompt(raw);
                render(enhanced);
                statusHint.textContent = `✓ enhanced (${currentMode})`;
                statusHint.style.color = 'var(--accent)';
                copyBtn.classList.remove('copied');
                copyBtn.textContent = 'copy';
            }

            enhanceBtn.addEventListener('click', handleEnhance);

            function handleClear() {
                inputEl.value = '';
                outputEl.innerHTML = '<span class="placeholder">enhanced prompt will appear here</span>';
                statusHint.textContent = 'cleared';
                statusHint.style.color = 'var(--text-muted)';
                copyBtn.classList.remove('copied');
                copyBtn.textContent = 'copy';
                updateCounts();
            }
            clearBtn.addEventListener('click', handleClear);

            function handleCopy() {
                const text = outputEl.textContent;
                if (!text || text.includes('enhanced prompt will appear here')) {
                    statusHint.textContent = '⚠️ nothing to copy';
                    statusHint.style.color = 'var(--text-muted)';
                    return;
                }
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(() => {
                        copyBtn.textContent = '✓ copied!';
                        copyBtn.classList.add('copied');
                        statusHint.textContent = 'copied to clipboard';
                        statusHint.style.color = 'var(--success)';
                        setTimeout(() => {
                            copyBtn.textContent = 'copy';
                            copyBtn.classList.remove('copied');
                        }, 2000);
                    }).catch(() => fallbackCopy(text));
                } else {
                    fallbackCopy(text);
                }
            }

            function fallbackCopy(text) {
                const ta = document.createElement('textarea');
                ta.value = text;
                document.body.appendChild(ta);
                ta.select();
                try {
                    document.execCommand('copy');
                    copyBtn.textContent = '✓ copied!';
                    copyBtn.classList.add('copied');
                    statusHint.textContent = 'copied to clipboard';
                    statusHint.style.color = 'var(--success)';
                    setTimeout(() => {
                        copyBtn.textContent = 'copy';
                        copyBtn.classList.remove('copied');
                    }, 2000);
                } catch (e) {
                    statusHint.textContent = '⚠️ copy failed';
                    statusHint.style.color = 'var(--text-muted)';
                }
                document.body.removeChild(ta);
            }
            copyBtn.addEventListener('click', handleCopy);

            // ─── keyboard shortcut ───
            inputEl.addEventListener('keydown', function(e) {
                if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
                    e.preventDefault();
                    handleEnhance();
                }
            });

            // ─── init ───
            updateCounts();
            statusHint.textContent = 'ready · ⌘+Enter';

        })();
    </script>
</body>
</html>
